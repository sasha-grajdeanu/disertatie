load maude/venus-lang-transition-machine.maude
load maude/venus-lang-testing.maude

mod TEST-EXTRACT3 is
    protecting VENUS-TS .
    protecting VENUS-TESTING .
endm

--- Simple assignment
reduce extractConstants('x := 5) .
--- Assignment with expression
reduce extractConstants('x := 'y + 3) .
--- While with constant in body
reduce extractConstants(while ('i lt 10) do 'i := 'i + 1 od) .

quit
