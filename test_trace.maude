load maude/venus-lang-transition-machine.maude
load maude/venus-lang-testing.maude

mod TEST-RUNNER is
    protecting VENUS-TS .
    protecting VENUS-TESTING .

    op testState : -> State .
    eq testState = < cCall('test) # cNil | 1 $ 2 | ('test => ['a , 'b, 'x := 'a ; 'y := 'b ; 'z := 1]) > .
endm

rewrite testState .
quit
