def 'risky_running_average ('n, 'total, 'count) {
    'i := 0
    'acc := 'total

    while ('i lt 'n) do
        if ('i lt 2) then
            'acc := 'acc + 'i + 1
        else
            'acc := 'acc + 2
        fi
        'i := 'i + 1
    od

    if ('acc gt 10) then
        'divisor := 'count - 'n
    else
        'divisor := 'count
    fi

    return 'acc / 'divisor
}
