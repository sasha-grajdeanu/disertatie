mod VENUS-DESUGARING is
    protecting VENUS-SYNTAX .

    vars Init Step : Inst .
    var Cond : BExpr .
    var Body : Inst .
    var I : Inst .

    eq I ; = I .

    eq for ( Init , Cond , Step ) do Body od = 
        Init ; 
        while Cond do 
            Body ; 
            Step 
        od .

    eq if Cond then Body fi = if Cond then Body else skip fi .
endm
