load maude/venus-lang-transition-machine.maude
load maude/venus-lang-testing.maude

mod TEST-EXTRACT2 is
    protecting VENUS-TS .
    protecting VENUS-TESTING .

    op body : -> Inst .
    eq body =
    'count := 0 ;
    'i := 0 ;
    while ('i lt 'n) do
        'count := 'count + 1 ;
        'i := 'i + 1
    od .

    op classifyBody : -> Inst .
    eq classifyBody =
    'sum := 0 ;
    'i := 1 ;
    while ('i lte 'n) do
        'sum := 'sum + 'i ;
        'i := 'i + 1
    od ;
    if ('sum gt 10) then
        'category := 2
    else
        if ('sum gt 0) then
            'category := 1
        else
            'category := 0
        fi
    fi .
endm

--- Test with just the body, not wrapped in def
reduce extractConstants(body) .
reduce genBoundaries(extractConstants(body)) .
reduce toIntSet(genBoundaries(extractConstants(body))) .
reduce 0 ;; 1 ;; toIntSet(genBoundaries(extractConstants(body))) .

reduce extractConstants(classifyBody) .
reduce 0 ;; 1 ;; toIntSet(genBoundaries(extractConstants(classifyBody))) .

quit
